# Local PostgreSQL
# Dung chung connection string cho Prisma runtime va migration khi chay local.
# Tao database bang pgAdmin 4, vi du database name: tomoio_local
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tomoio_local?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/tomoio_local?schema=public"

# Backend local
PORT=5000
NODE_ENV=development
JWT_SECRET=local-dev-secret-change-me
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:3000

# Cloudinary can cho cac API upload anh/CCCD.
# Neu chi xem UI voi seed data thi co the de trong.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# DeepL tuy chon cho dich tin nhan.
DEEPL_API_KEY=
DEEPL_API_URL=
