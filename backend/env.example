# Local PostgreSQL
# Dung chung connection string cho Prisma runtime va migration khi chay local.
# Tao database bang pgAdmin 4, vi du database name: tomoio
DATABASE_URL="postgresql://postgres:12345678@localhost:5432/tomoio?schema=public"
DIRECT_URL="postgresql://postgres:12345678@localhost:5432/tomoio?schema=public"

# Backend local
PORT=5001
NODE_ENV=development
JWT_SECRET=local-dev-secret-change-me
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:3000

# Cloudinary can cho cac API upload anh/CCCD.
# Neu chi xem UI voi seed data thi co the de trong.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare R2 cho upload anh/file production.
# Neu set day du cac bien nay, backend se uu tien R2 thay Cloudinary.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=tomoio-media
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_URL=
# Frontend Next.js image optimizer (custom R2 domain, optional if using *.r2.dev)
NEXT_PUBLIC_R2_PUBLIC_URL=
# Absolute app URL for resolving relative avatar paths in API responses (Hugging Face Space URL)
PUBLIC_APP_URL=

# DeepL tuy chon cho dich tin nhan.
DEEPL_API_KEY=
DEEPL_API_URL=
